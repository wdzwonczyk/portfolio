---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Skill from '../components/Skill.astro';
import ContactCTA from '../components/ContactCTA.astro';
import ProjectPreview from '../components/ProjectPreview.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import ExperienceLayout from '../layouts/ExperienceLayout.astro';
import CVLayout from '../layouts/CVLayout.astro';
import ProjectsLayout from '../layouts/ProjectsLayout.astro';

//Skills content
const skills = [
	{ 
		title: "Think in systems",
		iconHref: "../portfolio/assets/icons/problem-solution.svg",
		iconAlt: "Problem solving icon",
		text: "I break down complex problems into clear, structured solutions.",
	},
	{ 
		title: "Users over assumptions",
		iconHref: "../portfolio/assets/icons/precision-tool.svg",
		iconAlt: "User-Centered Design icon",
		text: "I rely on research and iteration to guide decisions.",
	},
	{ 
		title: "Care about the details",
		iconHref: "../portfolio/assets/icons/eye.svg",
		iconAlt: "Attention to details icon",
		text: "From flows to micro-interactions, I focus on what makes experiences feel right.",
	},
];
---

<Layout title="Wojciech Dzwonczyk | UX/UI Designer and Front-end Developer" description="Discover the world of UX/UI Design and Front-end Development through my portfolio. I specialize in creating captivating digital experiences that blend creativity and technical expertise. Explore my work and let's collaborate to bring your ideas to life.">
	<Hero title="Making Great Design Feel Effortless" subTitle="Hey, I’m Wojciech Dzwonczyk, a product designer turning ideas into polished, easy-to-use products."/>
	<main>
		<section class="py-8 md:py-16">
			<h2 class="h2">Key abilities and strengths</h2>
			<div class="flex flex-wrap gap-4 mt-8">
				{
					skills.map(({title, iconHref, iconAlt, text}) => (
						<Skill 
							title={title} 
							iconHref={iconHref} 
							iconAlt={iconAlt} 
							text={text}
						/>
					))
				}
			</div>
		</section>
		<ProjectsLayout>
			<h2 class="h2">Portfolio</h2>
		</ProjectsLayout>
		<ExperienceLayout/>
		<CVLayout href="../portfolio/assets/cv/Wojciech-Dzwonczyk-cv.pdf"/>
		<ContactCTA title="Let's shape the future Together!"/>
	</main>
</Layout>
